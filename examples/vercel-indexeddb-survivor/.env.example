# LLM endpoint for the agent (defaults to the keyless the3rdacademy endpoint).
# Swap for your own OpenAI/Anthropic-compatible provider.
LLM_BASE=https://the3rdacademy.com/api/v1
LLM_MODEL=claude-sonnet-4-6
# LLM_KEY=sk-...            # omit for keyless endpoints

# Survivor: pause the agent loop past this wall-clock budget (ms) so it spans the
# serverless function cap. Kept low here so the survivor visibly triggers in the
# demo; raise toward your platform's cap (e.g. Vercel Hobby ~290000) in prod.
MAX_DURATION_MS=20000
