# LLM endpoint (OpenAI-compatible /chat/completions). Set on the SERVER only —
# never expose the key to the browser. On Vercel: Project → Settings → Env Vars.
LLM_BASE=https://api.kilo.ai/api/gateway
LLM_MODEL=kilo-auto/free
LLM_KEY=sk-your-key

# Vercel KV (survivor session store). Auto-injected when you attach a KV store
# to the project; for local `vercel dev`, pull them with `vercel env pull`.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Lower to force the survivor pause→continue to trigger on short tasks (ms).
MAX_DURATION_MS=20000
