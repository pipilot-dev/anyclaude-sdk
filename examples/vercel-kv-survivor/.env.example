# LLM endpoint: keyless Kilo gateway (OpenAI-compatible, kilo-auto/free, ~200 req/hr free). LLM_KEY optional.
LLM_BASE=https://api.kilo.ai/api/gateway
LLM_MODEL=kilo-auto/free
LLM_KEY=

# Survivor pause budget in ms. Set LOW (e.g. 3000) to see the survivor
# pause + continue even on short tasks; production: just under your plan cap.
MAX_DURATION_MS=20000

# Vercel KV — create a KV store in the Vercel dashboard (Storage → KV) and link
# it to the project, then `vercel env pull .env` populates these automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=
