# LLM endpoint (defaults to the3rdacademy — keyless — if unset)
LLM_BASE=https://the3rdacademy.com/api/v1
LLM_MODEL=claude-sonnet-4-6
LLM_KEY=

# Supabase (Project Settings → API). Use the SERVICE ROLE key (server-side only).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Low budget so the survivor visibly triggers in the demo (ms). Raise for prod.
MAX_DURATION_MS=20000
