# LLM endpoint (defaults to Kilo gateway (requires an LLM key))
LLM_BASE=https://api.kilo.ai/api/gateway
LLM_MODEL=kilo-auto/free
LLM_KEY=

# Supabase (Project Settings → API). Use the SERVICE ROLE key (server-side only).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Low budget so the survivor visibly triggers in the demo (ms). Raise for prod.
MAX_DURATION_MS=20000
